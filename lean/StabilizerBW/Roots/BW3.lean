  ┬Ě intro h; have := h W8 inL3_W8; revert this; decide

/-- **T3: `g(xÔéüxÔéé + xÔéâ character) = 4`** (disjoint-support additivity `3 + 1 = 4`). -/
theorem grade3_mixed : grade3 mixed = 4 := by
