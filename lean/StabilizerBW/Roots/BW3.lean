  ┬╖ intro h; have := h W8 inL3_W8; revert this; decide

/-- **T3: `g(xέΓΒxέΓΓ + xέΓΔ character) = 4`** (disjoint-support additivity `3 + 1 = 4`). -/
theorem grade3_mixed : grade3 mixed = 4 := by
  apply grade3_eq_of (m := 4)
  ┬╖ unfold gradeLE3; apply mapsToL3_of_gens <;> decide
  ┬╖ intro h; have := h W8 inL3_W8; revert this; decide

/-! ## T4 έΑΦ the closed form is falsified -/

/-- The conjectured closed-form weight `w(d,╬╜) = max(0, 2^d έΙΤ 2^╬╜)`. -/
def wConj (d nu : έΕΧ) : έΕΧ := max 0 (2 ^ d - 2 ^ nu)

/-- The revised closed-form weight `w(d,╬╜) = max(0, 2┬╖d έΙΤ 2^╬╜)` that fits all data. -/
def wFit (d nu : έΕΧ) : έΕΧ := max 0 (2 * d - 2 ^ nu)

/-- **T4(i): the conjectured closed form `max(0, 2^d έΙΤ 2^╬╜)` is FALSIFIED.**
For `CCZ` (`d=3, ╬╜=2`) it predicts `4` but the true grade is `2`; for `CCS` (`3,1`) it
predicts `6` but the true grade is `4`; for `ccT` (`3,0`) it predicts `7` but the true
grade is `5`. -/
theorem closed_form_falsified :
    grade3 CCZ έΚι wConj 3 2 έΙπ grade3 CCS έΚι wConj 3 1 έΙπ grade3 ccT έΚι wConj 3 0 := by
  refine έθρ?_, ?_, ?_έθσ
  ┬╖ rw [grade3_CCZ]; decide
  ┬╖ rw [grade3_CCS]; decide
  ┬╖ rw [grade3_ccT]; decide

/-- **T4: the revised closed form `max(0, 2┬╖d έΙΤ 2^╬╜)` matches all three-qubit
single-monomial grades.** -/
theorem revised_form_holds :
    grade3 CCZ = wFit 3 2 έΙπ grade3 CCS = wFit 3 1 έΙπ grade3 ccT = wFit 3 0 := by
  refine έθρ?_, ?_, ?_έθσ
  ┬╖ rw [grade3_CCZ]; decide
  ┬╖ rw [grade3_CCS]; decide
  ┬╖ rw [grade3_ccT]; decide

/-- **T4(ii): disjoint-support additivity holds** for `xέΓΒxέΓΓ + xέΓΔ`:
`g(xέΓΒxέΓΓ+xέΓΔ) = g(cTέΛΩI) + g(TέΛΩIέΛΩI) = 3 + 1 = 4`. -/
theorem additivity_mixed : grade3 mixed = grade3 cTI + grade3 TII := by
  rw [grade3_mixed, grade3_cTI, grade3_TII]

end Roots