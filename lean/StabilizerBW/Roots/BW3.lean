import StabilizerBW.Roots.BW2

set_option maxHeartbeats 2000000

/-!
# The level-3 BarnesÔÇôWall lattice `BWÔéâ = LÔéł` and the n=3 diagonal grades

This file builds the three-qubit (8-dimensional) BarnesÔÇôWall lattice over `R = ÔäĄ[╬ÂÔéł]`
and computes the ╬╗-adic grades of the standard `n = 3` diagonal characters, extending
the two-qubit table of `Roots.BW2`.

We model an `8`-vector (basis order `000,001,ÔÇŽ,111`) as a pair `Vec4 ├Ś Vec4`, the
"low" half (`positions 0..3`) and the "high" half (`positions 4..7`).  The level-3
BarnesÔÇôWall recursion is the `(u, u + (1+i)┬Ěv)` construction:

```
BWÔéâ = LÔéł = { (hÔéÇ, hÔéü) : hÔéÇ Ôłł LÔéä,  hÔéü Ôłł LÔéä,  hÔéÇ - hÔéü Ôłł (1+i)┬ĚLÔéä }.
```

Equivalently this is the iterated `(1+i)`-divisibility tower of depth three: each half
lies in `LÔéä`, and the two halves agree modulo `(1+i)┬ĚLÔéä`.  We give a decidable
divisibility criterion `inL3`, prove it is an `R`-submodule generated by the eight
vectors `HßÁó`, and establish the reduction lemma "a diagonal operator preserves `LÔéł`
iff it preserves the eight generators."

The grade of a diagonal operator `D` is `g(D) = min k with ╬╗^k┬ĚD┬ĚLÔéł ÔŐć LÔéł`; we package
it as `gradeLE3 D k := MapsToL3 (scale8 (╬╗^k) D)`, mirroring `Roots.BW2`.

## Results (all kernel-checked)

Transport : `g(CZÔŐŚI)=0`, `g(TÔŐŚIÔŐŚI)=1`, `g(CSÔŐŚI)=2`, `g(cTÔŐŚI)=3`, `g(TÔŐŚTÔŐŚI)=2`.

New three-qubit column :
* `g(CCZ) = 2`   (`e = 4┬ĚxÔéüxÔééxÔéâ`, `(d,╬Ż) = (3,2)`),
* `g(CCS) = 4`   (`e = 2┬ĚxÔéüxÔééxÔéâ`, `(d,╬Ż) = (3,1)`),
* `g(ccT) = 5`   (`e = 1┬ĚxÔéüxÔééxÔéâ`, `(d,╬Ż) = (3,0)`),
* `g(xÔéüxÔéé+xÔéâ character) = 4`  (disjoint-support additivity: `3 + 1 = 4`).

These **falsify** the conjectured closed form `w(d,╬Ż) = max(0, 2^d Ôłĺ 2^╬Ż)` (which would
give `4, 6, 7`); see `Roots.BW3.closed_form_falsified`.  The actual data fit
`w(d,╬Ż) = max(0, 2┬Ěd Ôłĺ 2^╬Ż)`.
-/

namespace Roots
open Z8

/-- An 8-vector (basis order `000,ÔÇŽ,111`): low half `0..3`, high half `4..7`. -/
abbrev Vec8 := Vec4 ├Ś Vec4

/-- Coordinatewise difference on `Vec4`. -/
def vsub4 (v w : Vec4) : Vec4 := ÔčĘv.c0 - w.c0, v.c1 - w.c1, v.c2 - w.c2, v.c3 - w.c3Ôčę

@[simp] theorem vsub4_c0 (v w) : (vsub4 v w).c0 = v.c0 - w.c0 := rfl
@[simp] theorem vsub4_c1 (v w) : (vsub4 v w).c1 = v.c1 - w.c1 := rfl
@[simp] theorem vsub4_c2 (v w) : (vsub4 v w).c2 = v.c2 - w.c2 := rfl
@[simp] theorem vsub4_c3 (v w) : (vsub4 v w).c3 = v.c3 - w.c3 := rfl

/-! ## Membership in `BWÔéâ = LÔéł` (decidable divisibility criterion) -/

/-- The "difference" predicate: `d Ôłł (1+i)┬ĚLÔéä`, expanded as a divisibility tower.
`(1+i) Ôłú dÔ▒╝` (so `d/(1+i)` is integral), `(1+i)┬▓ Ôłú` the `LÔéä`-syndromes of `d`, and
`(1+i)┬│ Ôłú` the top syndrome. -/
def inDiff (d : Vec4) : Prop :=
  dvdOneI d.c0 Ôłž dvdOneI d.c1 Ôłž dvdOneI d.c2 Ôłž dvdOneI d.c3 Ôłž
  Even2 (d.c0 + d.c1) Ôłž Even2 (d.c2 + d.c3) Ôłž
  Even2 (d.c0 - d.c2) Ôłž Even2 (d.c1 - d.c3) Ôłž
  Even2 (d.c0 + d.c1 - d.c2 - d.c3) Ôłž dvdOneI (half (d.c0 + d.c1 - d.c2 - d.c3))

instance (d : Vec4) : Decidable (inDiff d) := by unfold inDiff Even2; infer_instance

/-- Membership in the level-3 BarnesÔÇôWall lattice `BWÔéâ = LÔéł`. -/
def inL3 (v : Vec8) : Prop :=
  inL2crit v.1 Ôłž inL2crit v.2 Ôłž inDiff (vsub4 v.1 v.2)

instance (v : Vec8) : Decidable (inL3 v) := by unfold inL3; infer_instance

instance : DecidablePred inL3 := fun _ => inferInstance

/-! ## Division by `(1+i)` -/

/-- Exact division by `1+i`: `z┬Ěconj(1+i)/2 = z┬Ě(1-i)/2 = z/(1+i)` (exact when `(1+i)Ôłúz`). -/
def divOneI (z : Z8) : Z8 := half (z * ÔčĘ1, 0, -1, 0Ôčę)

/-
If `(1+i) Ôłú z` then `(1+i)┬ĚdivOneI z = z`.
-/
theorem oneI_mul_divOneI {z : Z8} (h : oneI Ôłú z) : oneI * divOneI z = z := by
  obtain ÔčĘ y, rfl Ôčę := h;
  simp +decide [ divOneI, oneI ];
  simp +decide [ Z8.half ];
  congr <;> omega

/-
The recursive characterization: `inL3` is exactly the `(u, u+(1+i)v)` lattice.
-/
theorem inL3_iff_recursive (v : Vec8) :
    inL3 v Ôćö inL2 v.1 Ôłž inL2 v.2 Ôłž Ôłâ w : Vec4, inL2 w Ôłž vsub4 v.1 v.2 = vsmul4 oneI w := by
  constructor;
  ┬Ě intro h;
    obtain ÔčĘw, hwÔčę : Ôłâ w : Vec4, vsub4 v.1 v.2 = vsmul4 oneI w := by
      have h_div : ÔłÇ j : Fin 4, oneI Ôłú (vsub4 v.1 v.2).c0 Ôłž oneI Ôłú (vsub4 v.1 v.2).c1 Ôłž oneI Ôłú (vsub4 v.1 v.2).c2 Ôłž oneI Ôłú (vsub4 v.1 v.2).c3 := by
        exact fun j => ÔčĘ by simpa only [ dvdOneI_iff ] using h.2.2.1, by simpa only [ dvdOneI_iff ] using h.2.2.2.1, by simpa only [ dvdOneI_iff ] using h.2.2.2.2.1, by simpa only [ dvdOneI_iff ] using h.2.2.2.2.2.1 Ôčę;
      obtain ÔčĘw0, hw0Ôčę : Ôłâ w0 : Z8, (vsub4 v.1 v.2).c0 = oneI * w0 := h_div 0 |>.1
      obtain ÔčĘw1, hw1Ôčę : Ôłâ w1 : Z8, (vsub4 v.1 v.2).c1 = oneI * w1 := h_div 0 |>.2.1
      obtain ÔčĘw2, hw2Ôčę : Ôłâ w2 : Z8, (vsub4 v.1 v.2).c2 = oneI * w2 := h_div 0 |>.2.2.1
      obtain ÔčĘw3, hw3Ôčę : Ôłâ w3 : Z8, (vsub4 v.1 v.2).c3 = oneI * w3 := h_div 0 |>.2.2.2;
      exact ÔčĘ ÔčĘ w0, w1, w2, w3 Ôčę, by ext <;> tauto Ôčę;
    refine' ÔčĘ _, _, w, _, hw Ôčę;
    ┬Ě exact inL2_iff _ |>.2 h.1;
    ┬Ě exact inL2_iff _ |>.2 h.2.1;
    ┬Ě obtain ÔčĘhw1, hw2, hw3, hw4, hw5Ôčę := h.2.2;
      simp_all +decide [ inL2_iff ];
      unfold inL2crit; simp_all +decide [ Even2 ] ;
      simp_all +decide [ Z8.dvdOneI, Z8.half ];
      grind;
  ┬Ě simp +decide [ inL3, inL2_iff ];
    intro h1 h2 x hx h; simp_all +decide [ inL2crit, inDiff ] ;
    unfold Even2 at *; simp_all +decide [ Z8.dvdOneI ] ;
    simp_all +decide [ Z8.half ];
    omega

/-- The witness extracted from membership: a representative `w` of the difference. -/
theorem inL3_diff_exists {v : Vec8} (h : inL3 v) :
    Ôłâ w : Vec4, inL2 w Ôłž vsub4 v.1 v.2 = vsmul4 oneI w := by
  exact ((inL3_iff_recursive v).1 h).2.2

theorem inL3_fst {v : Vec8} (h : inL3 v) : inL2 v.1 := ((inL3_iff_recursive v).1 h).1

/-! ## `R`-module structure on `RÔüŞ` -/

/-- Scalar action of `R` on `RÔüŞ`. -/
def vsmul8 (r : Z8) (v : Vec8) : Vec8 := (vsmul4 r v.1, vsmul4 r v.2)

/-- Vector addition on `RÔüŞ`. -/
def vadd8 (v w : Vec8) : Vec8 := (vadd4 v.1 w.1, vadd4 v.2 w.2)

@[simp] theorem vsmul8_fst (r v) : (vsmul8 r v).1 = vsmul4 r v.1 := rfl
@[simp] theorem vsmul8_snd (r v) : (vsmul8 r v).2 = vsmul4 r v.2 := rfl
@[simp] theorem vadd8_fst (v w) : (vadd8 v w).1 = vadd4 v.1 w.1 := rfl
@[simp] theorem vadd8_snd (v w) : (vadd8 v w).2 = vadd4 v.2 w.2 := rfl

theorem inL3_add {v w : Vec8} (hv : inL3 v) (hw : inL3 w) : inL3 (vadd8 v w) := by
  obtain ÔčĘwv, hwv, hvwÔčę := inL3_diff_exists hv
  obtain ÔčĘww, hww, hww'Ôčę := inL3_diff_exists hw
  have h_diff : vsub4 (vadd4 v.1 w.1) (vadd4 v.2 w.2) = vsmul4 oneI (vadd4 wv ww) := by
    simp_all +decide [ vsub4, vadd4, vsmul4 ];
    simp_all +decide [ mul_add, add_sub_add_comm ];
  grind +suggestions

theorem inL3_vsmul (r : Z8) {v : Vec8} (hv : inL3 v) : inL3 (vsmul8 r v) := by
  convert ( inL3_iff_recursive ( vsmul8 r v ) ).2 _ using 1;
  refine' ÔčĘ _, _, _ Ôčę;
  ┬Ě exact inL2_vsmul r ( inL3_fst hv );
  ┬Ě exact inL2_vsmul r ( inL3_fst hv |> fun h => ( inL3_iff_recursive v |>.1 hv ) |>.2.1 |> fun h => by tauto );
  ┬Ě obtain ÔčĘ w, hwÔéü, hwÔéé Ôčę := inL3_diff_exists hv;
    refine' ÔčĘ vsmul4 r w, _, _ Ôčę;
    ┬Ě exact inL2_vsmul r hwÔéü;
    ┬Ě simp_all +decide [ vsub4, vsmul4, vsmul8 ];
      simp_all +decide [ ÔćÉ mul_sub, mul_left_comm ]

/-! ## Generators -/

/-- The 8 generators of `LÔéł`: `(GßÁó, GßÁó)` (the "diagonal" copy of `LÔéä`) and
`(0, (1+i)┬ĚGßÁó)` (the `(1+i)┬ĚLÔéä` difference part). -/
def H1 : Vec8 := (G1, G1)
def H2 : Vec8 := (G2, G2)
def H3 : Vec8 := (G3, G3)
def H4 : Vec8 := (G4, G4)
def H5 : Vec8 := (ÔčĘ0,0,0,0Ôčę, vsmul4 oneI G1)
def H6 : Vec8 := (ÔčĘ0,0,0,0Ôčę, vsmul4 oneI G2)
def H7 : Vec8 := (ÔčĘ0,0,0,0Ôčę, vsmul4 oneI G3)
def H8 : Vec8 := (ÔčĘ0,0,0,0Ôčę, vsmul4 oneI G4)

theorem inL3_H1 : inL3 H1 := by decide
theorem inL3_H2 : inL3 H2 := by decide
theorem inL3_H3 : inL3 H3 := by decide
theorem inL3_H4 : inL3 H4 := by decide
theorem inL3_H5 : inL3 H5 := by decide
theorem inL3_H6 : inL3 H6 := by decide
theorem inL3_H7 : inL3 H7 := by decide
theorem inL3_H8 : inL3 H8 := by decide

/-
Every `LÔéł` vector is an `R`-combination of `HÔéü,ÔÇŽ,HÔéł`.
-/
theorem inL3_decompose {v : Vec8} (hv : inL3 v) :
    Ôłâ a1 a2 a3 a4 b1 b2 b3 b4 : Z8,
      v = vadd8 (vsmul8 a1 H1) (vadd8 (vsmul8 a2 H2) (vadd8 (vsmul8 a3 H3)
            (vadd8 (vsmul8 a4 H4) (vadd8 (vsmul8 b1 H5) (vadd8 (vsmul8 b2 H6)
              (vadd8 (vsmul8 b3 H7) (vsmul8 b4 H8))))))) := by
  -- Apply `inL3_fst` and `inL3_diff_exists` to get `v.1` and `w`.
  obtain ÔčĘhwÔéü, hwÔééÔčę : inL2 v.1 Ôłž Ôłâ w : Vec4, inL2 w Ôłž vsub4 v.1 v.2 = vsmul4 oneI w := by
    exact ÔčĘ inL3_fst hv, inL3_diff_exists hv Ôčę;
  obtain ÔčĘw, hwÔéâ, hwÔéäÔčę := hwÔéé;
  obtain ÔčĘa1, a2, a3, a4, hvÔčę : Ôłâ a1 a2 a3 a4 : Z8, v.1 = vadd4 (vsmul4 a1 G1) (vadd4 (vsmul4 a2 G2) (vadd4 (vsmul4 a3 G3) (vsmul4 a4 G4))) := by
    obtain ÔčĘ a, al, be, hv Ôčę := inL2_decompose hwÔéü;
    exact ÔčĘ _, _, _, _, hv Ôčę
  obtain ÔčĘb1, b2, b3, b4, hwÔčę : Ôłâ b1 b2 b3 b4 : Z8, w = vadd4 (vsmul4 b1 G1) (vadd4 (vsmul4 b2 G2) (vadd4 (vsmul4 b3 G3) (vsmul4 b4 G4))) := by
    exact inL2_decompose hwÔéâ |> fun ÔčĘ a, al, be, hw Ôčę => ÔčĘ _, _, _, _, hw Ôčę;
  use a1, a2, a3, a4, -b1, -b2, -b3, -b4;
  simp_all +decide [ vsub4, vadd8, vsmul8, H1, H2, H3, H4, H5, H6, H7, H8 ];
  simp_all +decide [ vadd4, vsmul4, Prod.ext_iff ];
  exact Vec4.ext' ( by linear_combination -hwÔéä.1 ) ( by linear_combination -hwÔéä.2.1 ) ( by linear_combination -hwÔéä.2.2.1 ) ( by linear_combination -hwÔéä.2.2.2 )

/-! ## Diagonal operators and their grade -/

/-- A diagonal operator on `RÔüŞ`. -/
abbrev Diag8 := Vec8

/-- The action of a diagonal operator (componentwise multiplication). -/
def dapply8 (D v : Vec8) : Vec8 := (dapply D.1 v.1, dapply D.2 v.2)

/-- Scaling a diagonal operator by a ring element. -/
def scale8 (r : Z8) (D : Vec8) : Vec8 := (scale4 r D.1, scale4 r D.2)

@[simp] theorem dapply8_fst (D v) : (dapply8 D v).1 = dapply D.1 v.1 := rfl
@[simp] theorem dapply8_snd (D v) : (dapply8 D v).2 = dapply D.2 v.2 := rfl
@[simp] theorem scale8_fst (r D) : (scale8 r D).1 = scale4 r D.1 := rfl
@[simp] theorem scale8_snd (r D) : (scale8 r D).2 = scale4 r D.2 := rfl

theorem dapply8_add (D v w : Vec8) :
    dapply8 D (vadd8 v w) = vadd8 (dapply8 D v) (dapply8 D w) := by
  simp only [dapply8, vadd8, dapply_add]

theorem dapply8_vsmul (D : Vec8) (r : Z8) (v : Vec8) :
    dapply8 D (vsmul8 r v) = vsmul8 r (dapply8 D v) := by
  simp only [dapply8, vsmul8, dapply_vsmul]

theorem dapply8_scale8 (r : Z8) (D v : Vec8) :
    dapply8 (scale8 r D) v = vsmul8 r (dapply8 D v) := by
  simp only [dapply8, scale8, vsmul8, dapply_scale4]

/-- A diagonal operator maps `LÔéł` into `LÔéł`. -/
def MapsToL3 (D : Vec8) : Prop := ÔłÇ v, inL3 v Ôćĺ inL3 (dapply8 D v)

/-- **Reduction lemma.** A diagonal operator preserves `LÔéł` iff it preserves the eight
generators. -/
theorem mapsToL3_of_gens (D : Vec8)
    (h1 : inL3 (dapply8 D H1)) (h2 : inL3 (dapply8 D H2))
    (h3 : inL3 (dapply8 D H3)) (h4 : inL3 (dapply8 D H4))
    (h5 : inL3 (dapply8 D H5)) (h6 : inL3 (dapply8 D H6))
    (h7 : inL3 (dapply8 D H7)) (h8 : inL3 (dapply8 D H8)) : MapsToL3 D := by
  intro v hv
  obtain ÔčĘa1, a2, a3, a4, b1, b2, b3, b4, hdecÔčę := inL3_decompose hv
  rw [hdec]
  simp only [dapply8_add, dapply8_vsmul]
  exact inL3_add (inL3_vsmul _ h1) (inL3_add (inL3_vsmul _ h2) (inL3_add (inL3_vsmul _ h3)
    (inL3_add (inL3_vsmul _ h4) (inL3_add (inL3_vsmul _ h5) (inL3_add (inL3_vsmul _ h6)
      (inL3_add (inL3_vsmul _ h7) (inL3_vsmul _ h8)))))))

/-- `gradeLE3 D k`: the operator `╬╗^k ┬Ě D` maps `LÔéł` into `LÔéł`. -/
def gradeLE3 (D : Vec8) (k : ÔäĽ) : Prop := MapsToL3 (scale8 (Z8.lam ^ k) D)

theorem mapsToL3_scale (r : Z8) {D : Vec8} (h : MapsToL3 D) : MapsToL3 (scale8 r D) := by
  intro v hv
  rw [dapply8_scale8]
  exact inL3_vsmul r (h v hv)

/-- `gradeLE3` is upward closed. -/
theorem gradeLE3_succ {D : Vec8} {k : ÔäĽ} (h : gradeLE3 D k) : gradeLE3 D (k + 1) := by
  unfold gradeLE3 at *
  have hsc : scale8 (Z8.lam ^ (k + 1)) D = scale8 Z8.lam (scale8 (Z8.lam ^ k) D) := by
    simp only [scale8, scale4, Prod.mk.injEq, Vec4.mk.injEq]
    refine ÔčĘÔčĘ?_, ?_, ?_, ?_Ôčę, ?_, ?_, ?_, ?_Ôčę <;> ring
  rw [hsc]
  exact mapsToL3_scale Z8.lam h

/-- `gradeLE3` is monotone in `k`. -/
theorem gradeLE3_of_le {D : Vec8} {a b : ÔäĽ} (h : gradeLE3 D a) (hab : a ÔëĄ b) :
    gradeLE3 D b := by
  induction hab with
  | refl => exact h
  | step _ ih => exact gradeLE3_succ ih

/-
`(1+i)┬│ Ôłú ╬╗ÔüÂ` (since `╬╗┬▓ Ôł╝ 1+i`), so `╬╗ÔüÂ` lands every coordinate deep enough.
Every diagonal operator has grade `ÔëĄ 6`.
-/
theorem oneICube_dvd_lam_pow_six : (Z8.oneI * Z8.oneI * Z8.oneI) Ôłú Z8.lam ^ 6 := by
  convert dvd_mul_right ( oneI * oneI * oneI ) ( Z8.uu * Z8.uu * Z8.uu ) using 1

theorem gradeLE3_top (D : Vec8) : gradeLE3 D 6 := by
  intro v hv; simp_all +decide [ inL3_iff_recursive, inL2_iff ] ;
  refine' ÔčĘ _, _, _ Ôčę;
  ┬Ě simp_all +decide [ inL2crit, Even2 ];
    simp_all +decide [ scale4, Z8.dvdOneI ];
    simp_all +decide [ ÔćÉ even_iff_two_dvd, parity_simps ];
  ┬Ě simp_all +decide [ inL2crit, dapply, scale4 ];
    simp_all +decide [ Z8.dvdOneI, Even2 ];
    simp_all +decide [ ÔćÉ even_iff_two_dvd, parity_simps ];
  ┬Ě refine' ÔčĘ _, _, _ Ôčę;
    exact vsmul4 ( Z8.oneI * Z8.oneI * Z8.uu * Z8.uu * Z8.uu ) ( vsub4 ( dapply D.1 v.1 ) ( dapply D.2 v.2 ) );
    ┬Ě unfold inL2crit; simp +decide [ Even2 ] ;
      unfold Z8.dvdOneI; simp +decide ;
      grind;
    ┬Ě simp +decide [ vsub4, vsmul4, dapply, scale4 ];
      simp +decide [ mul_sub, sub_mul, mul_assoc, mul_comm, mul_left_comm ];
      exact ÔčĘ rfl, rfl, rfl, rfl Ôčę

theorem gradeLE3_nonempty (D : Vec8) : Ôłâ k, gradeLE3 D k := ÔčĘ6, gradeLE3_top DÔčę

/-- The grade `g(D) = min k with ╬╗^k┬ĚD┬ĚLÔéł ÔŐć LÔéł`. -/
noncomputable def grade3 (D : Vec8) : ÔäĽ := sInf {k | gradeLE3 D k}

theorem gradeLE3_grade (D : Vec8) : gradeLE3 D (grade3 D) :=
  Nat.sInf_mem (gradeLE3_nonempty D)

theorem grade3_le {D : Vec8} {k : ÔäĽ} (h : gradeLE3 D k) : grade3 D ÔëĄ k :=
  Nat.sInf_le h

theorem grade3_eq_zero {D : Vec8} (h0 : gradeLE3 D 0) : grade3 D = 0 :=
  Nat.le_zero.mp (Nat.sInf_le h0)

/-- If `╬╗^m┬ĚD` preserves `LÔéł` but `╬╗^{m-1}┬ĚD` does not, the grade is exactly `m`. -/
theorem grade3_eq_of {D : Vec8} {m : ÔäĽ} (hm : gradeLE3 D m)
    (hpred : ┬Č gradeLE3 D (m - 1)) : grade3 D = m := by
  have hmem : grade3 D Ôłł {k | gradeLE3 D k} := Nat.sInf_mem (gradeLE3_nonempty D)
  have hle : grade3 D ÔëĄ m := Nat.sInf_le hm
  rcases Nat.lt_or_ge (grade3 D) m with h | h
  ┬Ě exact absurd (gradeLE3_of_le hmem (by omega : grade3 D ÔëĄ m - 1)) hpred
  ┬Ě omega

/-! ## Sanity: the columns of `B^{ÔŐŚ3}` lie in `LÔéł` -/

/-- The 8 columns of `B^{ÔŐŚ3}` (`B = [[1+i,1],[0,1]]`) all lie in `BWÔéâ = LÔéł`,
anchoring that the divisibility criterion `inL3` captures the lattice generated by
`B^{ÔŐŚ3}`. -/
theorem inL3_BcubeCols :
    inL3 (ÔčĘZ8.oneI*Z8.oneI*Z8.oneI,0,0,0Ôčę, ÔčĘ0,0,0,0Ôčę) Ôłž
