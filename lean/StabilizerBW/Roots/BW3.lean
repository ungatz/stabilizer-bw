  ┬Ě unfold gradeLE3; apply mapsToL3_of_gens <;> decide
  ┬Ě intro h; have := h W8 inL3_W8; revert this; decide

/-! ## T4 ÔÇö the closed form is falsified -/

/-- The conjectured closed-form weight `w(d,╬Ż) = max(0, 2^d Ôłĺ 2^╬Ż)`. -/
def wConj (d nu : ÔäĽ) : ÔäĽ := max 0 (2 ^ d - 2 ^ nu)

/-- The revised closed-form weight `w(d,╬Ż) = max(0, 2┬Ěd Ôłĺ 2^╬Ż)` that fits all data. -/
def wFit (d nu : ÔäĽ) : ÔäĽ := max 0 (2 * d - 2 ^ nu)

/-- **T4(i): the conjectured closed form `max(0, 2^d Ôłĺ 2^╬Ż)` is FALSIFIED.**
For `CCZ` (`d=3, ╬Ż=2`) it predicts `4` but the true grade is `2`; for `CCS` (`3,1`) it
predicts `6` but the true grade is `4`; for `ccT` (`3,0`) it predicts `7` but the true
grade is `5`. -/
theorem closed_form_falsified :
    grade3 CCZ Ôëá wConj 3 2 Ôłž grade3 CCS Ôëá wConj 3 1 Ôłž grade3 ccT Ôëá wConj 3 0 := by
  refine ÔčĘ?_, ?_, ?_Ôčę
  ┬Ě rw [grade3_CCZ]; decide
  ┬Ě rw [grade3_CCS]; decide
  ┬Ě rw [grade3_ccT]; decide

/-- **T4: the revised closed form `max(0, 2┬Ěd Ôłĺ 2^╬Ż)` matches all three-qubit
single-monomial grades.** -/
theorem revised_form_holds :
    grade3 CCZ = wFit 3 2 Ôłž grade3 CCS = wFit 3 1 Ôłž grade3 ccT = wFit 3 0 := by
  refine ÔčĘ?_, ?_, ?_Ôčę
  ┬Ě rw [grade3_CCZ]; decide
  ┬Ě rw [grade3_CCS]; decide
  ┬Ě rw [grade3_ccT]; decide

/-- **T4(ii): disjoint-support additivity holds** for `xÔéüxÔéé + xÔéâ`:
`g(xÔéüxÔéé+xÔéâ) = g(cTÔŐŚI) + g(TÔŐŚIÔŐŚI) = 3 + 1 = 4`. -/
theorem additivity_mixed : grade3 mixed = grade3 cTI + grade3 TII := by
  rw [grade3_mixed, grade3_cTI, grade3_TII]

