/-! ## The witness for the lower bounds: `WÔéł = (GÔéü, GÔéü) Ôłł LÔéł` -/

/-- `WÔéł = (GÔéü, GÔéü)`, i.e. the all-`┬▒1` ReedÔÇôMuller vector `(1,-1,1,-1,1,-1,1,-1)`. -/
def W8 : Vec8 := (G1, G1)

theorem inL3_W8 : inL3 W8 := by decide

/-! ## T2 ÔÇö transport of the embedded two-qubit grades -/

/-- `CZ ÔŐŚ I = diag(1,1,1,1,1,1,-1,-1)`. -/
def CZI : Vec8 := (ÔčĘ1,1,1,1Ôčę, ÔčĘ1,1,-1,-1Ôčę)
/-- `T ÔŐŚ I ÔŐŚ I = diag(1,1,1,1,╬Â,╬Â,╬Â,╬Â)`. -/
def TII : Vec8 := (ÔčĘ1,1,1,1Ôčę, ÔčĘZ8.zeta,Z8.zeta,Z8.zeta,Z8.zetaÔčę)
/-- `CS ÔŐŚ I = diag(1,1,1,1,1,1,i,i)`. -/
def CSI : Vec8 := (ÔčĘ1,1,1,1Ôčę, ÔčĘ1,1,Z8.iu,Z8.iuÔčę)
/-- `cT ÔŐŚ I = diag(1,1,1,1,1,1,╬Â,╬Â)`. -/
def cTI : Vec8 := (ÔčĘ1,1,1,1Ôčę, ÔčĘ1,1,Z8.zeta,Z8.zetaÔčę)
/-- `T ÔŐŚ T ÔŐŚ I = diag(1,1,╬Â,╬Â,╬Â,╬Â,╬Â┬▓,╬Â┬▓)`. -/
def TTI : Vec8 := (ÔčĘ1,1,Z8.zeta,Z8.zetaÔčę, ÔčĘZ8.zeta,Z8.zeta,Z8.zeta^2,Z8.zeta^2Ôčę)

/-- **T2: `g(CZ ÔŐŚ I) = 0`.** -/
theorem grade3_CZI : grade3 CZI = 0 := by
  apply grade3_eq_zero
  unfold gradeLE3
  simp only [pow_zero]
  apply mapsToL3_of_gens <;> decide

/-- **T2: `g(T ÔŐŚ I ÔŐŚ I) = 1`.** -/
theorem grade3_TII : grade3 TII = 1 := by
  apply grade3_eq_of (m := 1)
  ┬Ě unfold gradeLE3; apply mapsToL3_of_gens <;> decide
  ┬Ě intro h; have := h W8 inL3_W8; revert this; decide

/-- **T2: `g(CS ÔŐŚ I) = 2`.** -/
theorem grade3_CSI : grade3 CSI = 2 := by
  apply grade3_eq_of (m := 2)
  ┬Ě unfold gradeLE3; apply mapsToL3_of_gens <;> decide
  ┬Ě intro h; have := h W8 inL3_W8; revert this; decide

/-- **T2: `g(cT ÔŐŚ I) = 3`.** -/
theorem grade3_cTI : grade3 cTI = 3 := by
  apply grade3_eq_of (m := 3)
  ┬Ě unfold gradeLE3; apply mapsToL3_of_gens <;> decide
  ┬Ě intro h; have := h W8 inL3_W8; revert this; decide

/-- **T2: `g(T ÔŐŚ T ÔŐŚ I) = 2`.** -/
theorem grade3_TTI : grade3 TTI = 2 := by
  apply grade3_eq_of (m := 2)
  ┬Ě unfold gradeLE3; apply mapsToL3_of_gens <;> decide
  ┬Ě intro h; have := h W8 inL3_W8; revert this; decide

/-! ## T3 ÔÇö the genuinely three-qubit diagonal characters -/

/-- `CCZ = diag(1,1,1,1,1,1,1,-1)` (`e = 4┬ĚxÔéüxÔééxÔéâ`). -/
def CCZ : Vec8 := (ÔčĘ1,1,1,1Ôčę, ÔčĘ1,1,1,-1Ôčę)
/-- `CCS = diag(1,ÔÇŽ,1,i)` (`e = 2┬ĚxÔéüxÔééxÔéâ`). -/
def CCS : Vec8 := (ÔčĘ1,1,1,1Ôčę, ÔčĘ1,1,1,Z8.iuÔčę)
/-- `ccT = diag(1,ÔÇŽ,1,╬Â)` (`e = 1┬ĚxÔéüxÔééxÔéâ`). -/
def ccT : Vec8 := (ÔčĘ1,1,1,1Ôčę, ÔčĘ1,1,1,Z8.zetaÔčę)
/-- The mixed character `e = xÔéüxÔéé + xÔéâ`: `diag(1,╬Â,1,╬Â,1,╬Â,╬Â,i)`. -/
def mixed : Vec8 := (ÔčĘ1,Z8.zeta,1,Z8.zetaÔčę, ÔčĘ1,Z8.zeta,Z8.zeta,Z8.iuÔčę)

/-- **T3: `g(CCZ) = 2`.** -/
theorem grade3_CCZ : grade3 CCZ = 2 := by
  apply grade3_eq_of (m := 2)
  ┬Ě unfold gradeLE3; apply mapsToL3_of_gens <;> decide
  ┬Ě intro h; have := h W8 inL3_W8; revert this; decide

/-- **T3: `g(CCS) = 4`.** -/
theorem grade3_CCS : grade3 CCS = 4 := by
