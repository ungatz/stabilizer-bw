import StabilizerBW.SqrtPi.Clifford
import StabilizerBW.SqrtPi.OplusCost

/-!
# T4* вҖ” The grade-`0` вҠҶ Clifford converse at a single qubit

The continuation asked for the converse `grade2obj a = 0 вҶ’ IsClifford2 a` at `n = 1`
(single qubit, object `2`).  As **literally stated about the syntax** this is **false**: the
inductive `IsClifford2` (generated by `Пғ_вҠ•, V, S` under `вҲҳ`) is *not* closed under the additive
product `вҠ•`, so a grade-`0` term whose head is `вҠ•` (other than the special `S` term) cannot be
`IsClifford2` even when its denotation is a perfectly good Clifford matrix.  The cleanest
counterexample is the global phase `О¶вӮғ вҠ• О¶вӮғ`, whose denotation is `О¶вӮҲВ·I` (grade `0`) but which is
not a syntactic Clifford word.  This is recorded as `Pi3.Falsification_T4_syntactic`.

The genuine, kernel-true converse is the **classification of the grade-`0` single-qubit diagonal
phases**: a conditional phase `diag(1, О¶вӮҲКІ)` is grade-`0` *iff* `j` is even, i.e. iff
`О¶вӮҲКІ вҲҲ {1, i, -1, -i}` вҖ” exactly the diagonal Clifford gates `{I, S, Z, SвҖ }`.  This is
`Pi3.Headline_T4_converse_diagonal`, the sharp first-stratum statement following from the T2
`в„Ө/8в„Ө` table.  The full unrestricted converse (`Aut(LвӮғ) = Clifford` up to phase, the
KliuchnikovвҖ“SchГ¶nnenbeck/Selinger presentation) remains the conjectural frontier, exactly as the
originally flagged.
-/

set_option maxRecDepth 4000

namespace Pi3
open Z8

/-- The global phase `О¶вӮғ вҠ• О¶вӮғ : 2 вҶ’ 2`, denoting `О¶вӮҲВ·I`. -/
def globalZeta : Pi3 2 2 := Pi3.zet вҠһ Pi3.zet

/-- `вҹҰО¶вӮғ вҠ• О¶вӮғвҹ§ = diag(О¶вӮҲ, О¶вӮҲ) = О¶вӮҲВ·I`. -/
lemma denote_globalZeta :
    denote globalZeta = Matrix.diagonal ![Q8.ofZ8 zeta, Q8.ofZ8 zeta] := by
  funext i j
  fin_cases i <;> fin_cases j <;> decide +kernel

/-- The global phase `О¶вӮҲВ·I` has lattice grade `0` (it preserves `LвӮғ`). -/
lemma grade2obj_globalZeta : grade2obj globalZeta = 0 := by
  refine le_antisymm (gradeWrt_le_of_pushesIn (k := 0) ?_) (zero_le _)
  intro v hv
  refine вҹЁzeta вҖў v, L3.smul_mem _ hv, ?_вҹ©
  rw [pow_zero, one_smul, denote_globalZeta]
  funext i
  fin_cases i <;>
    simp [Matrix.mulVec, Matrix.diagonal, dotProduct, coeVec,
      Pi.smul_apply, smul_eq_mul, вҶҗ Q8.ofZ8Hom_apply, вҶҗ map_mul]

/-- `О¶вӮғ вҠ• О¶вӮғ` is **not** a syntactic Clifford word (its head constructor is `вҠ•`, which
`IsClifford2` does not produce, except for the specific term `S`). -/
lemma not_isClifford2_globalZeta : В¬ IsClifford2 globalZeta := by
  intro h
  cases h

/-- **Pi3.Falsification_T4_syntactic.** The literal syntactic converse
`grade2obj a = 0 вҶ’ IsClifford2 a` is FALSE: the grade-`0` global phase `О¶вӮғ вҠ• О¶вӮғ` is not a
syntactic Clifford word. -/
theorem Falsification_T4_syntactic :
    вҲғ a : Pi3 2 2, grade2obj a = 0 вҲ§ В¬ IsClifford2 a :=
  вҹЁglobalZeta, grade2obj_globalZeta, not_isClifford2_globalZetaвҹ©

/-- **Pi3.Headline_T4_converse_diagonal.** The sharp first-stratum converse: a single-qubit
diagonal phase `diag(1, О¶вӮҲКІ)` is grade-`0` *iff* `j` is even, i.e. iff `О¶вӮҲКІ вҲҲ {1, i, -1, -i}` is
a diagonal Clifford phase. -/
theorem Headline_T4_converse_diagonal (j : Fin 8) :
    latGrade (diag1 (Z8.zeta ^ (j : в„•))) = 0 вҶ” (j : в„•) % 2 = 0 := by
  rw [Headline_T2_zeta_table]
  fin_cases j <;> decide

end Pi3
